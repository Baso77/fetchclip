{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/(.*\\.(html|css|js|svg|png|jpg|ico|json|txt|xml))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/backend/server.js"
    }
  ],
  "env": {
    "SUPABASE_URL": "process.env.SUPABASE_URL",
    "SUPABASE_ANON_KEY": "process.env.SUPABASE_ANON_KEY",
    "NODE_ENV": "production"
  }
}
